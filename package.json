{
  "name": "@buildry-wire/wire",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Wire payment API",
  "license": "MIT",
  "author": "Buildry",
  "homepage": "https://wire.mn",
  "repository": { "type": "git", "url": "https://github.com/buildry-wire/wire-node.git" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
